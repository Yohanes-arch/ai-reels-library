{
  "name": "ai-reels-library",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,black \"node server/index.js --api-only\" \"vite --host 0.0.0.0 --port 4173\"",
    "dev:client": "vite --host 0.0.0.0 --port 4173",
    "api": "node server/index.js --api-only",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "start": "node server/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@zip.js/zip.js": "^2.8.26",
    "concurrently": "^10.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "idb": "^8.0.3",
    "lucide-react": "^1.21.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.2",
    "vite": "^7.2.7",
    "vitest": "^4.1.9"
  }
}
